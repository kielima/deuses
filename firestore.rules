rules_version = '2';
// Regras do Firestore para o app colaborativo de deidades.
// Aplicar em: Firebase Console → Firestore Database → aba "Regras" → Publicar.
//
// Papéis:
//   master → edita todos os campos + revisão + comenta + resolve + gere papéis
//   admin  → edita o texto da Revisão (Markdown) + comenta + resolve
//   editor → comenta trechos da Revisão (threads + respostas)
//   viewer → só visualiza
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isMaster()   { return isSignedIn() && role() == 'master'; }
    function canReview()  { return isSignedIn() && role() in ['master', 'admin']; }
    function canComment() { return isSignedIn() && role() in ['master', 'admin', 'editor']; }

    // Catálogo: a base completa migrada para o Firestore, guardada em "chunks"
    // para caber no limite de 1 MiB por documento. Visível só após login;
    // só o master pode semear/editar a base.
    match /catalog/{chunk} {
      allow read:  if isSignedIn();
      allow write: if isMaster();
    }

    match /deities/{id} {
      allow read: if isSignedIn();
      // criar nova entrada: master ou admin (entradas novas têm id com prefixo "new_")
      allow create: if isMaster() || canReview();
      // editar: master qualquer campo; admin só o texto da revisão (+ metadados).
      // Isto garante que editar uma entrada (baseline OU nova) fica reservado ao master.
      allow update: if isMaster() ||
        (canReview() &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['review', 'lastEditedBy', 'lastEditedAt']));
      // excluir: só master
      allow delete: if isMaster();

      match /edits/{editId} {
        allow read: if isSignedIn();
        allow create: if canReview();
      }

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if canComment();
        // editores só podem acrescentar respostas (campo 'replies');
        // resolver/editar fica reservado a quem revisa (master/admin)
        allow update: if (canComment() &&
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies']))
                       || canReview();
        allow delete: if canReview();
      }
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if request.auth.uid == uid;
      // o próprio utilizador pode atualizar o perfil mas NÃO o seu role; o master define papéis
      allow update: if isMaster() ||
        (request.auth.uid == uid &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }
  }
}
